apiVersion: v1
kind: Namespace
metadata:
  name: {{ local_registry_namespace }}
---
apiVersion: apps/v1
kind: Deployment
metadata:
  name: local-registry
  namespace: {{ local_registry_namespace }}
spec:
  replicas: 1
  selector:
    matchLabels:
      app.kubernetes.io/name: local-registry
  template:
    metadata:
      labels:
        app.kubernetes.io/name: local-registry
    spec:
      hostNetwork: true
      dnsPolicy: ClusterFirstWithHostNet
      containers:
        - name: registry
          image: registry:2
          imagePullPolicy: IfNotPresent
          ports:
            - containerPort: 5000
              hostPort: 5000
              name: registry
          volumeMounts:
            - name: storage
              mountPath: /var/lib/registry
      volumes:
        - name: storage
          emptyDir: {}

